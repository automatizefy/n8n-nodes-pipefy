{
  "name": "n8n-nodes-pipefy",
  "version": "1.4.3",
  "description": "n8n community node for Pipefy API integration",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "pipefy"
  ],
  "license": "MIT",
  "homepage": "https://n8n.io",
  "author": {
    "name": "Tiago Cruz",
    "email": "tiago@automatizefy.com",
    "organization": "AutomatizeFY"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/automatizefy/n8n-nodes-pipefy.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist",
    "nodes/Pipefy/pipefy.svg"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PipefyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pipefy/Pipefy.node.js"
    ]
  },
  "dependencies": {
    "n8n-workflow": "^0.107.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/request-promise-native": "~1.0.18",
    "@typescript-eslint/eslint-plugin": "~5.45",
    "@typescript-eslint/parser": "~5.45",
    "eslint": "^8.29.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-core": "~0.125.0",
    "prettier": "^2.7.1",
    "typescript": "~4.8.4"
  }
}
